    "fig.suptitle(\"Normal Distribution Curves — Numerical Features\", fontsize=14, fontweight=\"bold\")\n",
    "\n",
    "for ax, col in zip(axes.flat, numerical_cols_raw):\n",
    "    data = security_df[col].dropna()\n",
    "    mu, std = data.mean(), data.std()\n",
